@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations

<EditForm Model="@workingModel" OnValidSubmit="Submit" FormName="userForm" class="user-form">
    <DataAnnotationsValidator />
    <ValidationSummary class="validation-summary" />

    <div class="form-group">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="workingModel.Name" />
        <ValidationMessage For="@(() => workingModel.Name)" />
    </div>

    <div class="form-group">
        <label class="form-label">Address</label>
        <InputText class="form-control" @bind-Value="workingModel.Address" />
    </div>

    <div class="form-group">
        <label class="form-label">Age</label>
        <InputNumber class="form-control" @bind-Value="workingModel.Age" />
        <ValidationMessage For="@(() => workingModel.Age)" />
    </div>

    <div class="form-group">
        <label class="form-label">Email</label>
        <InputText class="form-control" Value="@workingModel.Email" ValueChanged="@OnEmailChanged" ValueExpression="@(() => workingModel.Email)" />
        <ValidationMessage For="@(() => workingModel.Email)" />
    </div>

    <div class="form-actions">
        <button type="submit" class="save-button" disabled="@isSubmitting">
            @(ButtonText ?? "Submit")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p class="message">@Message</p>
    }
</EditForm>

@code {
    public enum FormMode { Create, Edit }

    [Parameter] public required UserModel Model { get; set; }
    [Parameter] public EventCallback<UserModel> OnSubmit { get; set; }
    [Parameter] public required string ButtonText { get; set; }
    [Parameter] public FormMode Mode { get; set; } = FormMode.Create;

    private UserModel workingModel = new() { Name = "", Address = "", Email = "" };
    private bool isSubmitting;
    private string Message = "";

    private static List<string> takenEmails = new() { "test@test.com" };

    protected override void OnParametersSet()
    {
        if (Mode == FormMode.Edit)
        {
            workingModel = new UserModel
            {
                Name = Model.Name,
                Address = Model.Address,
                Age = Model.Age,
                Email = Model.Email
            };
        }
        else
        {
            workingModel = Model;
        }
    }

    private async Task Submit()
    {
        if (isSubmitting) return;

        isSubmitting = true;

        await OnSubmit.InvokeAsync(workingModel);

        Message = "Saved successfully";

        isSubmitting = false;
    }

    private async Task OnEmailChanged(string value)
    {
        workingModel.Email = value;
        await CheckEmail();
    }

    private async Task CheckEmail()
    {
        await Task.Delay(200);

        if (!string.IsNullOrEmpty(workingModel.Email) && takenEmails.Contains(workingModel.Email.ToLower()))
        {
            Message = "Email already exists";
        }
        else
        {
            Message = "";
        }
    }
}